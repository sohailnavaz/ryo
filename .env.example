# Supabase — copy to .env.local in apps/web and apps/mobile as needed
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# For local seeding via psql
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# AI Concierge (server-side only — never exposed to the client).
# Get a key at https://console.anthropic.com. Set in apps/web/.env.local and in Vercel.
ANTHROPIC_API_KEY=
