  "version": 2,
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @bnb/web build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "apps/web/.next",
  "ignoreCommand": "false",
  "env": {
    "NEXT_PUBLIC_RYO_PREVIEW_MODE": "1"
  }
}
